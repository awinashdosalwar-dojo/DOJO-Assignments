{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "projectName": {
      "value": "myproject"
    },
    "environment": {
      "value": "prod"
    },
    "location": {
      "value": "eastus"
    },
    "webAppSku": {
      "value": "P1v3"
    },
    "webAppSkuCapacity": {
      "value": 2
    },
    "webAppRuntime": {
      "value": "NODE|18-lts"
    },
    "functionRuntime": {
      "value": "node"
    },
    "functionRuntimeVersion": {
      "value": "~4"
    },
    "sqlAdminLogin": {
      "value": "sqladmin"
    },
    "sqlAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/<RG_NAME>/providers/Microsoft.KeyVault/vaults/<KEYVAULT_NAME>"
        },
        "secretName": "sql-admin-password"
      }
    }
  }
}
